# ============================================
# CyberShield — Environment Configuration
# ============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Replace with your own MongoDB URI (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/cybershield

# JWT Secret — change this in production!
JWT_SECRET=cybershield_jwt_secret_key_2024_change_me

# JWT Expiry
JWT_EXPIRES_IN=7d
